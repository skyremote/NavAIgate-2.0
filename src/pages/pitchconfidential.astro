  'Tighten the bridge between product strategy, sales execution, and customer outcomes.',
  'Give leadership teams a senior operator who can shape the motion and build the assets around it.',
  'Prove AI value quickly through focused POCs before committing to full-scale investment.',
  'Equip leaders with a practical understanding of AI adoption and change management.',
];

const credibilityStats = [
  { value: '25+', label: 'Custom solutions' },
  { value: '10+', label: 'Enterprise clients' },
  { value: '50+', label: 'AI implementations' },
];
---

<BaseLayout
  title="Confidential Strategic Brief"
  description="Private overview of NavAIgate's strategic selling, leadership consulting, and outcome-driven product work."
>
  <script is:inline>
    (() => {
      const storedTheme = localStorage.getItem('pitchconfidential-theme');
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.pitchTheme = storedTheme || systemTheme;
    })();
  </script>

  <div class="pitch-shell">
    {!hasAccess ? (
      <main class="gate-wrap">
        <section class="gate-card">
          <p class="eyebrow">Private client preview</p>
          <h1>Confidential strategic brief for prospective partners.</h1>
          <p class="gate-copy">
            This page is a focused one-pager for how I position NavAIgate: leadership consulting,
            strategic selling support, and outcome-driven product work.
          </p>

          <form method="POST" class="gate-form">
            <label for="password" class="field-label">Password</label>
            <input
              id="password"
              name="password"
              type="password"
              class="field-input"
              placeholder="Enter password"
              autocomplete="current-password"
              required
              autofocus
            />
            {authError && <p class="error-text">{authError}</p>}
            <button type="submit" class="primary-button">Open brief</button>
          </form>
        </section>
      </main>
    ) : (
      <main class="brief-page">
        <section class="hero-panel">
          <div class="hero-topline">
            <span class="eyebrow">NavAIgate</span>
            <div class="hero-actions">
              <div class="theme-switch" role="group" aria-label="Theme toggle">
                <button type="button" class="theme-button is-active" data-theme-option="light" aria-pressed="true">
                  Light
                </button>
                <button type="button" class="theme-button" data-theme-option="dark" aria-pressed="false">
                  Dark
                </button>
              </div>
              <button type="button" class="ghost-button" data-print-brief>Save as PDF</button>
              <a href="/pitchconfidential?logout=1" class="ghost-link">Lock page</a>
            </div>
          </div>

          <div class="hero-grid">
            <div>
              <p class="mini-label">Strategic selling. AI adoption. Active operator context.</p>
              <h1>
                I help businesses sell more clearly, adopt AI pragmatically, and prove value fast.
              </h1>
              <p class="hero-copy">
                NavAIgate is how I package operator-led growth work: leading revenue teams, shaping
                enterprise narratives, building custom enablement software, improving internal systems,
                and running focused 4-8 week POCs that show whether an idea is worth scaling.
              </p>
              <div class="signal-row" aria-label="Core capabilities">
                <span>Strategic selling</span>
                <span>Enablement software</span>
                <span>Internal systems</span>
                <span>Leadership AI sessions</span>
              </div>
              <div class="stat-row" aria-label="Credibility highlights">
                {credibilityStats.map((stat) => (
                  <div class="stat-card">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))}
              </div>
            </div>

            <aside class="quote-card">
              <p class="quote-label">Elevator pitch</p>
              <p class="quote-text">
                I bring commercial leadership and product execution into the same room. I do not advise
                from the sidelines. I lead sales organisations, build custom enablement tools for
                enterprise clients, run AI leadership sessions with decision-makers, and turn that work
                into strategy, systems, and offers that companies can actually use.
              </p>
            </aside>
          </div>
        </section>

        <section class="content-grid">
          <div class="main-column">
            <section class="card-block intro-block reveal-card">
              <div class="section-head">
                <p class="eyebrow">Why clients bring me in</p>
                <h2>Strategic selling and AI execution from an operator, not a commentator.</h2>
              </div>

              <div class="pillars-grid">
                {advisoryPillars.map((pillar, index) => (
                  <article class="pillar-card reveal-card" style={`--reveal-delay:${index * 70}ms;`}>
                    <h3>{pillar.title}</h3>
                    <p>{pillar.description}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="card-block service-block reveal-card">
              <div class="section-head">
                <p class="eyebrow">How I work</p>
                <h2>Three ways I typically create momentum inside a business.</h2>
              </div>

              <div class="service-switch" role="tablist" aria-label="Service modes">
                {serviceModes.map((mode, index) => (
                  <button
                    type="button"
                    class:list={['service-chip', index === 0 && 'is-active']}
                    data-mode-target={mode.id}
                    role="tab"
                    aria-selected={index === 0 ? 'true' : 'false'}
                  >
                    {mode.label}
                  </button>
                ))}
              </div>

              <div class="service-stage">
                {serviceModes.map((mode, index) => (
                  <article
                    class:list={['service-panel', index === 0 && 'is-active']}
                    data-mode-panel={mode.id}
                  >
                    <div class="service-copy">
                      <p class="eyebrow">Mode {index + 1}</p>
                      <h3>{mode.title}</h3>
                      <p>{mode.description}</p>
                    </div>
                    <ul class="service-points">
                      {mode.bullets.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </article>
                ))}
              </div>
            </section>

            <section class="card-block proof-block reveal-card">
              <div class="section-head">
                <p class="eyebrow">Highlights of active work</p>
                <h2>The consultancy stays sharp because the work is happening right now.</h2>
              </div>

              <div class="proof-list">
                {proofPoints.map((point, index) => (
                  <article class="proof-card reveal-card" style={`--reveal-delay:${index * 90}ms;`}>
                    <div class="proof-head">
                      <div class="proof-logo-wrap">
                        <img src={point.logo} alt={point.logoAlt} class="proof-logo" />
                      </div>
                      <div>
                        <p class="proof-eyebrow">{point.eyebrow}</p>
                        <h3>{point.title}</h3>
                      </div>
                    </div>
                    <p class="proof-summary">{point.summary}</p>
                    <ul class="chip-row" aria-label={`${point.title} highlights`}>
                      {point.details.map((detail) => (
                        <li>{detail}</li>
                      ))}
                    </ul>
                  </article>
                ))}
              </div>
            </section>

            <section class="card-block portfolio-block reveal-card">
              <div class="section-head">
                <p class="eyebrow">Portfolio signal</p>
                <h2>The products I ship make the advisory sharper.</h2>
              </div>

              <div class="portfolio-grid">
                {productPortfolio.map((product, index) => (
                  <a
                    href={product.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="product-card reveal-card"
                    style={`--reveal-delay:${index * 90}ms;`}
                  >
                    <div class="product-logo-wrap">
                      <img src={product.logo} alt={product.name} class="product-logo" />
                    </div>
                    <div>
                      <h3>{product.name}</h3>
                      <p>{product.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          </div>

          <aside class="side-column">
            <section class="sidebar-card portrait-card reveal-card">
              <img src="/images/daniel.png" alt="Daniel Wright" class="portrait" />
              <div>
                <p class="eyebrow">Operator profile</p>
                <h2>Daniel Wright</h2>
                <p>
                  I founded NavAIgate to bring commercial leadership, practical AI implementation,
                  and product thinking into the same conversation.
                </p>
              </div>
            </section>

            <section class="sidebar-card reveal-card">
              <p class="eyebrow">How I can help</p>
              <h2>Typical engagement areas</h2>
              <div class="accordion" data-accordion>
                {engagementGroups.map((group, index) => (
                  <section class:list={['accordion-item', index === 0 && 'is-open']}>
                    <button
                      type="button"
                      class="accordion-trigger"
                      data-accordion-trigger
                      aria-expanded={index === 0 ? 'true' : 'false'}
                    >
                      <span>{group.title}</span>
                      <span class="accordion-plus" aria-hidden="true">+</span>
                    </button>
                    <div class:list={['accordion-panel', index === 0 && 'is-open']} data-accordion-panel>
                      <p>{group.body}</p>
                    </div>
                  </section>
                ))}
              </div>
            </section>

            <section class="sidebar-card outcome-card reveal-card">
              <p class="eyebrow">What clients leave with</p>
              <h2>Expected outcomes</h2>
              <ul class="outcome-list">
                {outcomes.map((outcome) => (
                  <li>{outcome}</li>
                ))}
              </ul>
            </section>

            <section class="sidebar-card cta-card reveal-card">
              <p class="eyebrow">Next step</p>
              <h2>If this is the problem set, the conversation is straightforward.</h2>
              <p>
                If your business needs stronger strategic selling, clearer market narrative, or a senior
                operator to connect product decisions to revenue outcomes, this is where I typically help.
              </p>
              <a
                href="mailto:dw@navaigate.dev?subject=NavAIgate%20Strategic%20Brief"
                class="primary-link"
              >
                dw@navaigate.dev
              </a>
              <a href="https://navaigate.dev" class="secondary-link">Visit navaigate.dev</a>
            </section>
          </aside>
        </section>
      </main>
    )}
  </div>

  <script is:inline>
    (() => {
      const storageKey = 'pitchconfidential-theme';
      const root = document.documentElement;
      const themeButtons = document.querySelectorAll('[data-theme-option]');
      const printButton = document.querySelector('[data-print-brief]');
      let prePrintTheme = null;
      const setTheme = (theme) => {
        root.dataset.pitchTheme = theme;
        themeButtons.forEach((button) => {
          const isActive = button.dataset.themeOption === theme;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', String(isActive));
        });
      };

      const storedTheme = localStorage.getItem(storageKey);
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      setTheme(storedTheme || systemTheme);

      themeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const theme = button.dataset.themeOption;
          if (!theme) return;
          localStorage.setItem(storageKey, theme);
          setTheme(theme);
        });
      });

      const forcePrintTheme = () => {
        prePrintTheme = root.dataset.pitchTheme || localStorage.getItem(storageKey) || systemTheme;
        root.dataset.pitchTheme = 'light';
      };

      const restorePrintTheme = () => {
        if (!prePrintTheme) return;
        root.dataset.pitchTheme = prePrintTheme;
        prePrintTheme = null;
      };

      if (printButton) {
        printButton.addEventListener('click', async () => {
          forcePrintTheme();
          await new Promise((resolve) => requestAnimationFrame(() => requestAnimationFrame(resolve)));
          window.print();
        });
      }

      window.addEventListener('beforeprint', forcePrintTheme);
      window.addEventListener('afterprint', restorePrintTheme);

      const modeButtons = document.querySelectorAll('[data-mode-target]');
      const modePanels = document.querySelectorAll('[data-mode-panel]');
      const modeSwitch = document.querySelector('.service-switch');

      const setMode = (mode) => {
        modeButtons.forEach((button) => {
          const isActive = button.dataset.modeTarget === mode;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-selected', String(isActive));
          if (isActive && modeSwitch) {
            modeSwitch.style.setProperty('--active-left', `${button.offsetLeft}px`);
            modeSwitch.style.setProperty('--active-width', `${button.offsetWidth}px`);
          }
        });

        modePanels.forEach((panel) => {
          panel.classList.toggle('is-active', panel.dataset.modePanel === mode);
        });
      };

      if (modeButtons.length && modePanels.length) {
        setMode(modeButtons[0].dataset.modeTarget || 'sell');
        modeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const mode = button.dataset.modeTarget;
            if (mode) setMode(mode);
          });
        });
      }

      window.addEventListener('resize', () => {
        const activeMode = document.querySelector('[data-mode-target].is-active')?.dataset.modeTarget;
        if (activeMode) setMode(activeMode);
      });

      document.querySelectorAll('[data-accordion]').forEach((accordion) => {
        const items = accordion.querySelectorAll('.accordion-item');
        items.forEach((item) => {
          const trigger = item.querySelector('[data-accordion-trigger]');
          const panel = item.querySelector('[data-accordion-panel]');
          if (!trigger || !panel) return;

          trigger.addEventListener('click', () => {
            const willOpen = !item.classList.contains('is-open');
            items.forEach((entry) => {
              entry.classList.remove('is-open');
              entry.querySelector('[data-accordion-trigger]')?.setAttribute('aria-expanded', 'false');
              entry.querySelector('[data-accordion-panel]')?.classList.remove('is-open');
            });

            if (willOpen) {
              item.classList.add('is-open');
              trigger.setAttribute('aria-expanded', 'true');
              panel.classList.add('is-open');
            }
          });
        });
      });

      const revealCards = document.querySelectorAll('.reveal-card');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );

      revealCards.forEach((card) => observer.observe(card));
    })();
  </script>
</BaseLayout>

<style is:global>
  :root,
  html[data-pitch-theme='light'] {
    --page-bg:
      radial-gradient(circle at 12% 14%, rgba(0, 205, 160, 0.16), transparent 24%),
      radial-gradient(circle at 84% 12%, rgba(0, 144, 255, 0.14), transparent 28%),
      linear-gradient(180deg, #f4f7fb 0%, #edf2f7 100%);
    --surface: rgba(255, 255, 255, 0.72);
    --surface-strong: rgba(255, 255, 255, 0.86);
    --surface-soft: rgba(14, 30, 37, 0.05);
    --line: rgba(15, 23, 42, 0.10);
    --line-strong: rgba(15, 23, 42, 0.18);
    --text-main: #0f172a;
    --text-soft: rgba(15, 23, 42, 0.72);
    --text-faint: rgba(15, 23, 42, 0.56);
    --accent: #0090ff;
    --accent-2: #00cda0;
    --accent-soft: linear-gradient(135deg, rgba(0, 144, 255, 0.16), rgba(0, 205, 160, 0.18));
    --shadow: 0 24px 80px rgba(15, 23, 42, 0.10);
    --hero-glow: rgba(0, 144, 255, 0.14);
    --cta-bg: linear-gradient(160deg, #07111f 0%, #10233a 100%);
    --cta-text: #f8fbff;
  }

  html[data-pitch-theme='dark'] {
    --page-bg:
      radial-gradient(circle at 12% 14%, rgba(0, 205, 160, 0.12), transparent 24%),
      radial-gradient(circle at 84% 12%, rgba(0, 144, 255, 0.16), transparent 28%),
      linear-gradient(180deg, #06111b 0%, #0b1724 100%);
    --surface: rgba(7, 18, 32, 0.76);
    --surface-strong: rgba(9, 23, 38, 0.92);
    --surface-soft: rgba(255, 255, 255, 0.05);
    --line: rgba(255, 255, 255, 0.09);
    --line-strong: rgba(255, 255, 255, 0.16);
    --text-main: #eef7ff;
    --text-soft: rgba(238, 247, 255, 0.78);
    --text-faint: rgba(238, 247, 255, 0.58);
    --accent: #44b0ff;
    --accent-2: #3be0b8;
    --accent-soft: linear-gradient(135deg, rgba(68, 176, 255, 0.20), rgba(59, 224, 184, 0.18));
    --shadow: 0 28px 90px rgba(0, 0, 0, 0.30);
    --hero-glow: rgba(68, 176, 255, 0.18);
    --cta-bg: linear-gradient(160deg, #ecf6ff 0%, #d8efff 100%);
    --cta-text: #07111f;
  }

  body {
    background: var(--page-bg);
    color: var(--text-main);
    transition: background 0.35s ease, color 0.35s ease;
  }

  .pitch-shell {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    isolation: isolate;
    font-family: 'Poppins', sans-serif;
    color: var(--text-main);
  }

  .pitch-shell::before,
  .pitch-shell::after {
    content: '';
    position: fixed;
    inset: auto;
    width: 26rem;
    height: 26rem;
    border-radius: 999px;
    filter: blur(70px);
    opacity: 0.34;
    z-index: -1;
    animation: ambientFloat 18s ease-in-out infinite;
    pointer-events: none;
  }

  .pitch-shell::before {
    top: 6%;
    right: -6rem;
    background: rgba(0, 144, 255, 0.16);
  }

  .pitch-shell::after {
    bottom: 10%;
    left: -7rem;
    background: rgba(0, 205, 160, 0.16);
    animation-delay: -8s;
  }

  .pitch-shell h1,
  .pitch-shell h2,
  .pitch-shell h3 {
    font-family: 'Poppins', sans-serif;
    letter-spacing: -0.045em;
  }

  .gate-wrap,
  .brief-page {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
  }

