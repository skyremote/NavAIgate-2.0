---
import BaseLayout from '../layouts/BaseLayout.astro';

const COOKIE_NAME = 'navaigate_pitch_access';
const DEFAULT_PASSWORD = 'navaigate2024';
const routePath = '/pitchconfidential';
const pitchPassword = import.meta.env.PITCH_PAGE_PASSWORD ?? DEFAULT_PASSWORD;
const requestUrl = new URL(Astro.request.url);

if (requestUrl.searchParams.get('logout') === '1') {
  Astro.cookies.delete(COOKIE_NAME, { path: routePath });
  return Astro.redirect(routePath);
}

let authError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const submittedPassword = String(formData.get('password') ?? '').trim();

  if (submittedPassword === pitchPassword) {
    Astro.cookies.set(COOKIE_NAME, 'granted', {
      path: routePath,
      httpOnly: true,
      sameSite: 'lax',
      secure: import.meta.env.PROD,
      maxAge: 60 * 60 * 8,
    });

    return Astro.redirect(routePath);
  }

  authError = 'Incorrect password. Please try again.';
}

const hasAccess = Astro.cookies.get(COOKIE_NAME)?.value === 'granted';

const advisoryPillars = [
  {
    title: 'Revenue Leadership & Strategic Selling',
    description:
      'Hands-on commercial leadership for businesses that need executive sales structure, sharper deal strategy, and a more disciplined route to revenue.',
  },
  {
    title: 'Custom Enablement Software',
    description:
      'We build bespoke tools that help teams sell products more effectively, reduce prep time, automate repetitive work, and give users the right information at the right moment.',
  },
  {
    title: 'Internal System Optimisation',
    description:
      'Auditing and improving existing internal systems so they actually serve the people using them. Less friction, better data, faster decisions.',
  },
  {
    title: 'Proof-of-Concept Sprints',
    description:
      'Focused 4–8 week POCs that prove R&D value inside the business before committing to a full build. Designed to de-risk investment and show measurable outcomes early.',
  },
  {
    title: 'AI Leadership Sessions',
    description:
      'On-site and virtual sessions with leadership teams to guide AI adoption, address change management, and align the organisation around what AI can realistically deliver.',
  },
  {
    title: 'Strategic Selling Systems',
    description:
      'Positioning, enterprise messaging, account planning, and decision frameworks that help teams sell complex offers with more clarity and consistency.',
  },
];

const engagementTracks = [
  'Executive sales and GTM advisory',
  'Founder-led sales maturation',
  'Enterprise positioning and strategic messaging',
  'AI-enabled workflow and process design',
  'Product-to-market narrative development',
  'Team cadence, pipeline discipline, and deal inspection',
  'On-site AI leadership workshops',
  'Change management guidance for AI adoption',
  '4–8 week proof-of-concept sprints',
  'Internal tooling audits and optimisation',
];

const engagementGroups = [
  {
    title: 'Strategic selling advisory',
    body:
      'Narrative refinement, account planning, pipeline discipline, forecasting cadence, and sharper leadership visibility into how revenue work is actually progressing.',
  },
  {
    title: 'AI product and system work',
    body:
      'Custom enablement software, internal system optimisation, and focused POCs that prove whether an idea creates measurable value before the business overcommits.',
  },
  {
    title: 'Leadership alignment and adoption',
    body:
      'On-site sessions with leadership teams around AI adoption, change management, practical implementation paths, and where AI should fit into the operating model.',
  },
];

const serviceModes = [
  {
    id: 'sell',
    label: 'Sell',
    title: 'I help teams sell complex offers with more clarity.',
    description:
      'This is where I focus on strategic selling: tightening the narrative, improving how accounts are worked, and creating a commercial motion that leaders can actually inspect and scale.',
    bullets: [
      'Enterprise positioning and message clarity',
      'Account planning and deal inspection',
      'Pipeline discipline, forecasting, and cadence',
      'Founder and leadership support for sales maturation',
    ],
  },
  {
    id: 'build',
    label: 'Build',
    title: 'I build the systems and software that support the motion.',
    description:
      'When the bottleneck is internal execution, I build or scope the tools around it. That can mean custom enablement software, system optimisation, or a short POC that proves the opportunity before a larger investment.',
    bullets: [
      'Custom enablement software for users and teams',
      'Internal system optimisation and workflow redesign',
      '4-8 week AI and R&D proof-of-concept sprints',
      'Practical measures for time saved and friction reduced',
    ],
  },
  {
    id: 'lead',
    label: 'Lead',
    title: 'I work directly with leadership teams on adoption and change.',
    description:
      'AI only changes a business when leadership is aligned on why it matters, what it should change, and how the organisation will adopt it. I help guide that conversation in practical terms.',
    bullets: [
      'On-site AI leadership sessions and workshops',
      'Change management guidance for adoption',
      'Decision support around where AI should and should not be applied',
      'Operating plans that connect product direction to revenue outcomes',
    ],
  },
];

const proofPoints = [
  {
    eyebrow: 'Consultancy in action',
    title: 'Global Sales Leadership',
    logo: '/logos/katana.svg',
    logoAlt: 'Katana',
    summary:
      'Currently leading a global sales organisation, which directly informs how we approach every consultancy engagement. The consulting is sharper because the operating experience is live — not historical.',
    details: ['Active GTM execution', 'Enterprise deal cycles', 'Revenue strategy and team design'],
  },
  {
    eyebrow: 'Enterprise client work',
    title: 'Custom AI Enablement',
    logo: '/logos/NavAIgate.svg',
    logoAlt: 'NavAIgate',
    summary:
      'Building outcome-driven technology for enterprise clients that enables their teams through custom software, streamlines internal workflows, and reduces time spent on repetitive tasks so teams can sell and execute more effectively.',
    details: ['Workflow-led AI tools', '4-8 week POCs', 'Measured time savings'],
  },
  {
    eyebrow: 'Owned portfolio',
